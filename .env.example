# ResumeForge Environment Variables

# Authentication (required in production)
JWT_SECRET_KEY=
# Optional: token lifetime in minutes (default 43200 = 30 days)
# ACCESS_TOKEN_EXPIRE_MINUTES=43200

# CORS (comma-separated origins; default allows local dev)
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-3.5-turbo

# Embedding Model Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Frontend API URL (for local development)
VITE_API_URL=http://localhost:8000/api

# Optional: File Upload Limits (in bytes)
MAX_FILE_SIZE=10485760  # 10MB default

# Optional: ChromaDB Configuration
CHROMA_DB_PATH=./chroma_db

# Database Configuration
DATABASE_URL=sqlite:///./resumeforge.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/resumeforge
# For MySQL: DATABASE_URL=mysql://user:password@localhost/resumeforge

# Storage Configuration
STORAGE_TYPE=local
# For AWS S3: STORAGE_TYPE=s3
# S3_BUCKET_NAME=your-bucket-name
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
